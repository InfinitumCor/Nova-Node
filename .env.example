# Nova configuration
# Everything here stays on your machine.

# ── Her mind ──
# "ollama" = local & completely free (default). Nothing leaves your machine.
# "anthropic" = Claude API (optional upgrade; paid key required).
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Voice (optional — free Edge-TTS is used when unset) ──
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
TTS_PROVIDER=edge

# ── Wake word (optional — press-Enter wake when unset) ──
# Free key: https://console.picovoice.ai/
# PICOVOICE_ACCESS_KEY=

# ── Audio device (optional — system default when unset) ──
# NOVA_AUDIO_DEVICE=

# ── Timezone (IANA name) ──
NOVA_TIMEZONE=America/Chicago
