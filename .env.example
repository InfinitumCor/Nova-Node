# ══════════════════════════════════════════════
# NOVA — Environment Configuration
# Copy this file to .env and fill in your values
# Infinitum Cor LLC
# ══════════════════════════════════════════════

# ── LLM: Anthropic Claude ──
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── TTS: ElevenLabs ──
# Get a key at: https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Wake Word: Picovoice (Optional) ──
# Without a key, Nova runs in STUB wake mode (press ENTER to wake).
# Get a free access key at: https://picovoice.ai
PICOVOICE_ACCESS_KEY=

# ── Audio Device (Optional) ──
# Index of your input device (mic). Leave blank for system default.
NOVA_AUDIO_DEVICE=

# ── TTS Backend Selection ──
# "elevenlabs" (paid, higher quality) or "edge" (free Microsoft voices, fallback)
TTS_PROVIDER=elevenlabs

# ── Timezone ──
# IANA timezone string (e.g. America/Chicago, Europe/London, Asia/Tokyo)
NOVA_TIMEZONE=America/Chicago
